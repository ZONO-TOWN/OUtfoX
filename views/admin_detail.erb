<div class="detail-wrapper">
    
    <div class="detail-top">
        <img class="kv" src="/assets/kv/<%= @play.kv %>">
        
        <div class="play-detail">
            <h1 class="title"> <%= @play.title %> </h1>
            <% min = @play.schedules.minimum(:day) %>
            <% max = @play.schedules.maximum(:day) %>
            <h2 class="date">
                <%  if min == max %>
                    <%= min.strftime("%-Y年%-m月%-d日") %>
                <%  else %>
                    <%= min.strftime("%-Y年%-m月%-d日") %> ~ <%= max.strftime("%-Y年%-m月%-d日") %>
                <% end %>
            </h2>
            <p> <%= @play.description %> </p>
        </div>
    </div>
    
    <hr class="separator">
    
    
    <div class="detail-bottom">
        <div class="dates">
            <% @schedule_days.each_with_index do |(day, schedules), index| %>
            <div class="date-tab <%= 'active' if index == 0 %>" onclick="showDate('<%= day %>', this)">
                <%= day.strftime("%-m/%-d") %>（<%= %w(日 月 火 水 木 金 土)[day.wday] %>）
            </div>
            <% end %>
        </div>
        
        <div class="times">
            <% @schedule_days.each_with_index do |(day, schedules), index| %>
                <div id="<%= day %>" class="schedule" style="<%= 'display: none;' if index > 0 %>">
                    <div class="sche-wrapper">
                        <% schedules.each do |sche| %>
                        <button class="book-button" onclick="showTable('<%= sche.id %>', this)">
                            <p> <%= sche.time.strftime("%H:%M") %> ~ <%= (sche.time + sche.duration * 60).strftime("%H:%M") %></p>
                        </button>
                        <% end %>
                    </div>
                </div>
            <% end %>
        </div>
    </div>
    
    <div class="table-container">
        <% @play.schedules.each do |sche| %>
        <div id="table-<%= sche.id %>" class="booking-table" style="display: none;">
            <h3><%= sche.day.strftime("%-m/%-d") %> <%= sche.time.strftime("%H:%M") %> の予約者一覧</h3>
            <table class="admin-table">
              <thead>
                <tr>
                <th onclick="sortTable(this, 0)" style="cursor: pointer;">代表者名</th>
                  <th onclick="sortTable(this, 1)" style="cursor: pointer;">メールアドレス</th>
                  <th onclick="sortTable(this, 2)" style="cursor: pointer;">予約番号</th>
                  <th onclick="sortTable(this, 3)" style="cursor: pointer;">予約人数</th> 
                  <th onclick="sortTable(this, 4)" style="cursor: pointer;">得点</th>
                </tr>
              </thead>
              <tbody>
                  <% sche_books = @books.select { |b| b.schedule_id == sche.id } %>
                  <% sche_books.each do |book| %>
                  <% guests = book.guests
                  
                     if guests.any?
                        total_score = guests.sum { |g| g.score }
                        avg = total_score / guests.count
                     else
                        avg = 0
                     end
                     
                     leader = guests.first %>
                  <tr>
                    <td> <%= leader.guest_name %> </td>
                    <td> <%= book.user.mail %> </td>
                    <td> <%= book.id %> </td>
                    <td> <%= book.headcount %></td>
                    <td> <%= avg %> </td>
                  </tr>
                  <% end %>
              </tbody>
            </table>
        </div>
        <% end %>
    </div>
</div>

<script>
function showDate(day, clickedTab) {
    const allLists = document.querySelectorAll('.schedule');
    allLists.forEach(list => 
    {
        list.style.display = 'none';
    });
    
    const selectedList = document.getElementById(day);
    if (selectedList) 
    {
        selectedList.style.display = 'block';
    }

    const allTabs = document.querySelectorAll('.date-tab');
    allTabs.forEach(tab => 
    {
        tab.classList.remove('active');
    });
    
    if (clickedTab) {
        clickedTab.classList.add('active');
    }
    
    document.querySelectorAll('.booking-table').forEach(table => table.style.display = 'none');
    document.querySelectorAll('.book-button').forEach(btn => btn.classList.remove('active'));
}

function showTable(scheduleId,clickedBtn) 
{
    const allTables = document.querySelectorAll('.booking-table');
    allTables.forEach(table => 
    {
        table.style.display = 'none';
    });
    
    const selectedTable = document.getElementById('table-' + scheduleId);
    if (selectedTable) 
    {
        selectedTable.style.display = 'block';
    }
    
    if (clickedBtn) 
    {
        document.querySelectorAll('.book-button').forEach(btn => btn.classList.remove('active'));
        clickedBtn.classList.add('active');
    }
}

function sortTable(Element, Index) {
    const table = Element.closest('table');
    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));

    rows.sort((a, b) => {
        const valA = a.querySelectorAll('td')[Index].textContent.trim();
        const valB = b.querySelectorAll('td')[Index].textContent.trim();

        if (Index === 2) {
            const numA = parseFloat(valA) || 0;
            const numB = parseFloat(valB) || 0;
            return numA - numB; 
        }
        else if (Index == 3 || Index == 4) {
            const numA = parseFloat(valA) || 0;
            const numB = parseFloat(valB) || 0;
            return numB - numA; 
        } else {
            return valA.localeCompare(valB, 'ja');
        }
    });

    // 並び替えた結果をテーブルに戻す
    rows.forEach(row => tbody.appendChild(row));
}
</script>
